        "            fila['date'] - DateOffset(months=1),\n",
        "            fila['date'] + DateOffset(months=1),\n",
        "            fila['date'] + DateOffset(months=2),\n",
        "        ]\n",
        "    elif fila['date'].month == 7:\n",
        "        nuevas_fechas = [\n",
        "            fila['date'] - DateOffset(months=3),\n",
        "            fila['date'] - DateOffset(months=2),\n",
        "            fila['date'] - DateOffset(months=1),\n",
        "            fila['date'] + DateOffset(months=1),\n",
        "            fila['date'] + DateOffset(months=2),\n",
        "        ]\n",
        "    else:\n",
        "        nuevas_fechas = [fila['date']]\n",
        "\n",
        "\n",
        "    df_reemplazo = pd.DataFrame({\n",
        "        'date': nuevas_fechas,\n",
        "        **{col: [fila[col]] * len(nuevas_fechas) for col in fila.index if col != 'date'}\n",
        "    })\n",
        "    return df_reemplazo\n",
        "\n",
        "\n",
        "for index, fila in bigmac.iterrows():\n",
        "    if fila['date'].month == 1 or fila['date'].month == 7:\n",
        "        dfs_reemplazados.append(fila.to_frame().T)\n",
        "        df_reemplazo = ajustar_fechas(fila)\n",
        "        dfs_reemplazados.append(df_reemplazo)\n",
        "    else:\n",
        "        dfs_reemplazados.append(fila.to_frame().T)\n",
        "\n",
        "\n",
        "df_final = pd.concat(dfs_reemplazados, ignore_index=True)\n",
        "\n",
        "\n",
        "df_final.head()"
      ]
